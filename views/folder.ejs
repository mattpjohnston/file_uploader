<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell">
      <section class="panel">
        <h1><%= currentFolder.name %></h1>
        <p class="meta">Signed in as <strong><%= currentUser.email %></strong>.</p>
        <% if (currentFolder.parent) { %>
          <p><a href="/folders/<%= currentFolder.parent.id %>">Back to <%= currentFolder.parent.name %></a></p>
        <% } else { %>
          <p><a href="/dashboard">Back to dashboard</a></p>
        <% } %>
        <% if (error) { %>
          <p class="message error"><%= error %></p>
        <% } %>
        <% if (success) { %>
          <p class="message success"><%= success %></p>
        <% } %>

        <section class="section">
          <h2>Create a subfolder</h2>
          <form class="form-grid" action="/folders" method="post">
            <input name="parentId" type="hidden" value="<%= currentFolder.id %>" />
            <label>
              Folder name
              <input name="name" required type="text" />
            </label>
            <button class="button" type="submit">Create folder</button>
          </form>
        </section>

        <section class="section">
          <h2>Upload a file</h2>
          <form class="form-grid" action="/upload" enctype="multipart/form-data" method="post">
            <input name="folderId" type="hidden" value="<%= currentFolder.id %>" />
            <label>
              Select a file
              <input name="file" required type="file" />
            </label>
            <p class="form-note">Allowed files: PNG, JPG, PDF, TXT. Maximum size: 5 MB.</p>
            <button class="button" type="submit">Upload file</button>
          </form>
        </section>

        <section class="section">
          <h2>Folders</h2>
          <% if (folders.length === 0) { %>
            <p class="empty-state">No folders yet.</p>
          <% } else { %>
            <ul class="item-list">
              <% folders.forEach((folder) => { %>
                <li class="item-card">
                  <a class="item-title" href="/folders/<%= folder.id %>"><%= folder.name %></a>
                  <p class="item-meta">Created <%= new Date(folder.createdAt).toLocaleString() %></p>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>

        <section class="section">
          <h2>Files</h2>
          <% if (files.length === 0) { %>
            <p class="empty-state">No files in this folder yet.</p>
          <% } else { %>
            <ul class="item-list">
              <% files.forEach((file) => { %>
                <li class="item-card">
                  <a class="item-title" href="/files/<%= file.id %>"><%= file.name %></a>
                  <p class="item-meta"><%= file.size %> bytes</p>
                  <p class="item-meta">Uploaded <%= new Date(file.createdAt).toLocaleString() %></p>
                  <p class="item-links">
                    <a href="/files/<%= file.id %>">View details</a>
                    <a href="/files/<%= file.id %>/download">Download</a>
                  </p>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>

        <p><a href="/">Home</a></p>
        <form action="/logout" method="post">
          <button class="button" type="submit">Log out</button>
        </form>
      </section>
    </main>
  </body>
</html>
