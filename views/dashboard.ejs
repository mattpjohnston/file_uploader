<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell">
      <section class="panel">
        <h1><%= title %></h1>
        <p class="meta">Signed in as <strong><%= currentUser.email %></strong>.</p>
        <p>Upload files below.</p>
        <% if (error) { %>
          <p class="message error"><%= error %></p>
        <% } %>
        <% if (success) { %>
          <p class="message success"><%= success %></p>
        <% } %>
        <form class="form-grid" action="/upload" enctype="multipart/form-data" method="post">
          <label>
            Select a file
            <input name="file" required type="file" />
          </label>
          <button class="button" type="submit">Upload file</button>
        </form>
        <p><a href="/">Home</a></p>
        <form action="/logout" method="post">
          <button class="button" type="submit">Log out</button>
        </form>
      </section>
    </main>
  </body>
</html>
